using ITI.Application.Dtos;
using ITI.Application.Interfaces.Services;
using System.ComponentModel;
using System.Drawing;
using System.Windows.Forms;

namespace ITI.WinForms
{
    public class InstractorForm : Form
    {
        private readonly IInstractorService instractorService;

        private DataGridView grid;
        private TextBox fNameTxt;
        private TextBox lNameTxt;
        private TextBox phoneTxt;
        private NumericUpDown deptIdNum;
        private Button addBtn;
        private Button updateBtn;
        private Button deleteBtn;

        public InstractorForm(IInstractorService instractorService)
        {
            this.instractorService = instractorService;
            InitializeComponent();
            LoadInstractors();
        }

        private void InitializeComponent()
        {
            Text = "Instructors";
            ClientSize = new Size(700, 500);

            grid = new DataGridView { Location = new Point(20, 20), Size = new Size(640, 250), ReadOnly = true, AutoGenerateColumns = true };
            fNameTxt = new TextBox { Location = new Point(120, 290), Size = new Size(200, 25) };
            lNameTxt = new TextBox { Location = new Point(120, 330), Size = new Size(200, 25) };
            phoneTxt = new TextBox { Location = new Point(120, 370), Size = new Size(200, 25) };
            deptIdNum = new NumericUpDown { Location = new Point(120, 410), Size = new Size(100, 25), Minimum = 0, Maximum = 100000 };

            var fnLbl = new Label { Text = "FirstName", Location = new Point(20, 290), Size = new Size(80, 25) };
            var lnLbl = new Label { Text = "LastName", Location = new Point(20, 330), Size = new Size(80, 25) };
            var phLbl = new Label { Text = "Phone", Location = new Point(20, 370), Size = new Size(80, 25) };
            var diLbl = new Label { Text = "DepartmentId", Location = new Point(20, 410), Size = new Size(80, 25) };

            addBtn = new Button { Text = "Add", Location = new Point(360, 290), Size = new Size(100, 30) };
            updateBtn = new Button { Text = "Update", Location = new Point(360, 330), Size = new Size(100, 30) };
            deleteBtn = new Button { Text = "Delete", Location = new Point(360, 370), Size = new Size(100, 30) };

            Controls.AddRange(new Control[] { grid, fNameTxt, lNameTxt, phoneTxt, deptIdNum, fnLbl, lnLbl, phLbl, diLbl, addBtn, updateBtn, deleteBtn });

            addBtn.Click += AddBtn_Click;
            updateBtn.Click += UpdateBtn_Click;
            deleteBtn.Click += DeleteBtn_Click;
            grid.SelectionChanged += Grid_SelectionChanged;
        }

        private void LoadInstractors()
        {
            var list = instractorService.GetAll().ToList();
            grid.DataSource = null;
            grid.DataSource = new BindingList<AllInstractorDto>(list);
        }

        private void AddBtn_Click(object? sender, EventArgs e)
        {
            var dto = new CreateInstractorDto(fNameTxt.Text, lNameTxt.Text, phoneTxt.Text, (int)deptIdNum.Value);
            instractorService.Add(dto);
            ClearInputs();
            LoadInstractors();
        }

        private void UpdateBtn_Click(object? sender, EventArgs e)
        {
            if (grid.CurrentRow?.DataBoundItem is AllInstractorDto dto)
            {
                var update = new UpdateInstractorDto(dto.Id, fNameTxt.Text, lNameTxt.Text, phoneTxt.Text, (int)deptIdNum.Value);
                instractorService.Update(update);
                LoadInstractors();
            }
        }

        private void DeleteBtn_Click(object? sender, EventArgs e)
        {
            if (grid.CurrentRow?.DataBoundItem is AllInstractorDto dto)
            {
                var r = MessageBox.Show("Delete this instructor?", "Confirm", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);
                if (r == DialogResult.Yes)
                {
                    instractorService.Delete(dto.Id);
                    LoadInstractors();
                    ClearInputs();
                }
            }
        }

        private void Grid_SelectionChanged(object? sender, EventArgs e)
        {
            if (grid.CurrentRow?.DataBoundItem is AllInstractorDto dto)
            {
                fNameTxt.Text = dto.FirstName ?? string.Empty;
                lNameTxt.Text = dto.LastName ?? string.Empty;
                phoneTxt.Text = dto.Phone ?? string.Empty;
            }
        }

        private void ClearInputs()
        {
            fNameTxt.Text = string.Empty;
            lNameTxt.Text = string.Empty;
            phoneTxt.Text = string.Empty;
            deptIdNum.Value = 0;
        }
    }
}
