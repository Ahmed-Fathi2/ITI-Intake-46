@using WebApplication2.ViewModel
@model CategoryCreateVM

<style>

    label {
        color: #198754
    }
</style>
<div class="d-flex justify-content-center">
    <h1 class="text-success">Create Category</h1>
</div>

<br />
<hr />
<br />

<form action="~/Category/Create" method="post">

    <div class="form-group mb-3">
        <label for="Name">Name</label>
        <input type="text" class="form-control" id="Name" name="Name" placeholder="Enter Category Name" required>
    </div>

    <div class="form-group mb-3">
        <label for="Description">Description</label>
        <input type="text" class="form-control" id="Description" name="Description" placeholder="Enter Category Description" required>
    </div>




    <div class="d-flex justify-content-center gap-2">
        <button type="submit" class="btn btn-success">Create Category</button>
        <a href="~/Category/Index" class="btn btn-secondary"> Cancel</a>
    </div>
</form>

