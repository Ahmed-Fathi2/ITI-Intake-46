@using WebApplication2.ViewModel
@model CategoryEditVM

<style>

    label {
        color: #198754
    }
</style>
<div class="d-flex justify-content-center">
    <h1 class="text-success">Update Category</h1>
</div>

<br />
<hr />
<br />

<form action="~/Category/Edit" method="post">

    <div class="form-group mb-3">
        <label for="Id">Id</label>
        <input type="text" class="form-control" value="@Model.Id" id="Id" name="Id" required readonly>
    </div>

    <div class="form-group mb-3">
        <label for="Name">Name</label>
        <input type="text" class="form-control" value="@Model.Name" id="Name" name="Name" required>
    </div>

    <div class="form-group mb-3">
        <label for="Description">Description</label>
        <input type="text" class="form-control" id="Description" value="@Model.Description" name="Description" placeholder="Enter Product Description" required>
    </div>








    <div class="d-flex justify-content-center gap-2">
        <button type="submit" class="btn btn-success">Save</button>
        <a href="~/Category/Index" class="btn btn-secondary"> Cancel</a>
    </div>
</form>

