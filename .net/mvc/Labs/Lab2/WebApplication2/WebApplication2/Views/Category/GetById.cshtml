@using WebApplication2.ViewModel
@model CategoryReadVM

<style>

    body {
        background: #f8f9fa;
    }

    .card-box {
        width: 500px;
        margin: auto;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0,0,0,.1);
        background: white;
    }

    h1 {
        font-weight: 600;
    }

    h2 {
        font-size: 20px;
        margin-bottom: 10px;
    }

    span {
        color: limegreen;
        font-weight: 600;
        margin-left: 5px;
    }

    .back-btn {
        margin-top: 15px;
    }

</style>

<div class="card-box">

    <div class="d-flex justify-content-center mb-3">
        <h1 class="text-success">Product Details</h1>
    </div>

    <div class="d-flex flex-column gap-2 mb-2">
        <h2>Name : <span>@Model.Name</span></h2>
        <h2>Description : <span>@Model.Description</span></h2>
    </div>

    <a class="btn btn-primary back-btn" href="~/Category/Index">Back To List</a>

</div>