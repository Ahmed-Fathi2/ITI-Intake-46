@using WebApplication2.ViewModel
@model ProductCreateVM

<style>

    label{
        color:#198754
    }
</style>
<div class="d-flex justify-content-center">
    <h1 class="text-success">Create Product</h1>
</div>

<br />
<hr />
<br />

@* <form action="~/Product/Create" method="post"> *@
  @* @using(Html.BeginForm("Create","Product",FormMethod.Post))
    {

    } *@
@* </form> *@


        <form asp-action="Create" asp-controller="Product" enctype="multipart/form-data" >

    <div class="form-group mb-3">

        @* <label for="Name">Name</label> *@
        @* @Html.LabelFor(x => x.Name, new { @class = "form-label" }) *@
        @* <input type="text" class="form-control" id="Name" name="Name" placeholder="Enter Product Name" required> *@
        @* type / id / name  / value *@
        @* @Html.TextBoxFor(x => x.Name, new { @class = "form-control", Placeholder = "Enter Product Name V22" })  *@

        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" placeholder="Enter Product Name" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Description"></label>
        <input asp-for="Description" class="form-control" placeholder="Enter Product Description">
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        @* <label for="Price">Price</label> *@
        @* @Html.LabelFor(x => x.Price, new { @class = "form-label" }) *@
        @* @* <input type="number" class="form-control" id="Price" name="Price" placeholder="Enter Product Price" required> *@
        @* @Html.EditorFor(x => x.Price, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter Product Price" } }) *@


        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" placeholder="Enter Product Price" />
        <span asp-validation-for="Price" class="text-danger"></span>

    </div>

    <div class="form-group mb-3">

        @* <input type="number" class="form-control" id="Count" name="Count" placeholder="Enter Product Count" > *@
        <label asp-for="Count" class="form-label"></label>
        <input asp-for="Count" class="form-control" placeholder="Enter Product Count" />
        <span asp-validation-for="Count" class="text-danger"></span>
    </div>

    <div class="form-group mb-3" >
        <label asp-for="Image" class="form-label"></label>
        <input asp-for="Image" class="form-control" type="file" />
        <span asp-validation-for="Image" class="text-danger"></span>
    </div>


    <div class="form-group mb-3">
        <label for="Category">Category</label>

        @* <select class="form-select"  id="Category" name="CategoryId" >
                @foreach (var option in Model.Categories!)
                    {
                    <option value="@option.Value">@option.Text</option>
                    }
            </select>    *@

        <select asp-for="CategoryId" class="form-select" asp-items="Model.Categories">
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-center gap-2">
        <button type="submit" class="btn btn-success">Create Product</button>
        @* <a href="~/Product/Index" class="btn btn-secondary"> Cancel</a> *@
        @Html.ActionLink("Cancel", "Index", "Product", null, new { @class = "btn btn-secondary" })
    </div>

        </form>

@section Scripts
{
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}