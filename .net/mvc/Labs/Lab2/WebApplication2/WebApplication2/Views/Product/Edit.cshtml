@using WebApplication2.ViewModel
@model ProductEditVM

<style>

    label {
        color: #198754
    }
</style>
<div class="d-flex justify-content-center">
    <h1 class="text-success">Update Product</h1>
</div>

<br />
<hr />
<br />

<form  asp-action="Edit" asp-controller="Product" method="post">

    <div class="form-group mb-3">

        <label asp-for="Id" class="form-label"></label>
        <input asp-for="Id" class="form-control"  readonly />

    </div>

    <div class="form-group mb-3">

        @* <label for="Name">Name</label> *@

        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" required />
    </div>

    <div class="form-group mb-3">
        
        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-control" required />
    </div>

    <div class="form-group mb-3">
        @* <label for="Price">Price</label> *@
        @* <input type="number" class="form-control" id="Price" value="@Model.Price" name="Price" placeholder="Enter Product Price" required> *@

        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" required />
    </div>

    <div class="form-group mb-3">
        @* <label for="Count">Count</label>
        <input type="number" class="form-control" id="Count" value="@Model.Count" name="Count" placeholder="Enter Product Count" required> *@

        <label asp-for="Count" class="form-label"></label>
        <input asp-for="Count" class="form-control" required />
    </div>


    <div class="form-group mb-3">

      @*   <label for="Category">Category</label>

        <select class="form-select" id="Category"  name="CategoryId" required>

            <option value="@Model.CategoryId">@Model.CategoryName</option>
            @foreach (var option in Model.Categories!)
            {
                    if (option.Value == Model.CategoryId.ToString())
                    {
                        continue;
                    }
                    <option value="@option.Value">@option.Text</option>
            }
   

        </select> *@

        <label asp-for="CategoryId" class="form-label"></label>
        <select class="form-select" asp-for="CategoryId" asp-items="Model.Categories"></select>
    </div>



    <div class="d-flex justify-content-center gap-2">
        <button type="submit" class="btn btn-success">Save</button>
        @* <a href="~/Product/Index" class="btn btn-secondary"> Cancel</a> *@
        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary"> Cancel</a>
    </div>
</form>

