@using WebApplication2.ViewModel
@model ProductCategoryReadVM


<div class="mb-3 form-group">
<label asp-for="CategoryId" class="form-label"></label>
    <select id="catDropDown" asp-for="CategoryId" class="form-select" asp-items="@Model.Categories"></select>

</div> 

<div class="mb-3 form-group">
    <label>Products</label>
    <select id="proDropDown" class="form-select">
        <option value="">-- Select Product --</option>
    </select>
</div>


<div id="productTable">
    @* Product table will load here *@
</div>
@section Scripts {
    <script>

        $(document).ready(function () {

            $("#catDropDown").change(function () {

                var catId = $(this).val();

                if (catId !== "") {

                    $.ajax({
                        url: '/ProductCategory/GetAllRelatedProduct',
                        type: 'GET',
                        data: { catId: catId },

                        success: function (products) {

                            $("#proDropDown").empty();
                            $("#proDropDown").append(
                                `<option value="">-- Select Product --</option>`
                            );

                            $.each(products, function (i, pro) {

                                $("#proDropDown").append(
                                    `<option value="${pro.productId}">${pro.productName}</option>`
                                );

                            });

                        },

                        error: function () {
                            alert("Error loading products");
                        }

                    });

                }

            });
               $("#proDropDown").change(function () {

                var id = $(this).val();

                if (id !== "") {

                    $.ajax({
                        url: '/ProductCategory/GetById',
                        type: 'GET',
                        data: { id: id },

                        success: function (product) {
                            $("#productTable").html(product)
                         
                        },

                        error: function () {
                            alert("Error loading product");
                        }

                    });

                }

            });
        });

    </script>
}