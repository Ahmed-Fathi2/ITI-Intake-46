﻿<h1 style="color:green; text-align:center;">
    All Products
</h1>

<table class="table">
    <thead>
        <tr>
            <th scope="col">Id</th>
            <th scope="col">Name</th>
            <th scope="col">Description</th>
            <th scope="col">Price</th>
            <th scope="col">Count</th>
            <th scope="col">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <th>@product.Id</th>
                <th>@product.Name</th>
                <td>@product.Description</td>
                <td>@product.Price</td>
                <td>@product.Count</td>
                <td>
                    <a class="btn btn-primary" href="~/Product/GetById/@product.Id">
                        View Details
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

