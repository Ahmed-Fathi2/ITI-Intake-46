@page "/exams/{subjectId:int}"
@attribute [Authorize]

<PageTitle>Exams</PageTitle>

@if (subject != null)
{
    <MudText Typo="Typo.h4" GutterBottom="true">Exams for @subject.Name</MudText>

    <MudGrid>
        @foreach (var exam in exams)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4" Class="pa-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@exam.Title</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@exam.Description</MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">Duration: @exam.DurationMinutes minutes</MudText>
                        <MudText Typo="Typo.body2">Questions: @exam.Questions.Count</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        @if (IsExamCompleted(exam.Id))
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="@($"/result/{GetCompletedExamId(exam.Id)}")">View Result</MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => StartExam(exam.Id)">Start Exam</MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [Parameter] public int SubjectId { get; set; }

    private Subject? subject;
    private List<Exam> exams = new();
    private Dictionary<int, int> completedExams = new(); // ExamId -> StudentExamId

    [Inject] private ApplicationDbContext DbContext { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthState { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        // Redirect admins away from student pages
        if (user.Identity?.IsAuthenticated == true && user.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/admin/dashboard");
            return;
        }

        var userId = user.FindFirst("sub")?.Value ?? user.Identity?.Name;

        subject = await DbContext.Subjects.Include(s => s.Exams).FirstOrDefaultAsync(s => s.Id == SubjectId);
        if (subject != null)
        {
            exams = await DbContext.Exams
                .Include(e => e.Questions)
                .Where(e => e.SubjectId == SubjectId)
                .ToListAsync();
        }

        if (userId != null)
        {
            var completed = await DbContext.StudentExams
                .Where(se => se.StudentId == userId && se.SubmittedAt.HasValue)
                .ToListAsync();
            foreach (var se in completed)
            {
                completedExams[se.ExamId] = se.Id;
            }
        }
    }

    private bool IsExamCompleted(int examId) => completedExams.ContainsKey(examId);

    private int GetCompletedExamId(int examId) => completedExams[examId];

    private async Task StartExam(int examId)
    {
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = authState.User;

            // prefer NameIdentifier claim, fall back to Name
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                         ?? user.FindFirst("sub")?.Value
                         ?? user.Identity?.Name;

            if (string.IsNullOrEmpty(userId))
            {
                // Not authenticated properly - redirect to login
                Snackbar.Add("Please login to start the exam.", Severity.Warning);
                Navigation.NavigateTo("/Account/Login");
                return;
            }

            // Check if already taken
            var existing = await DbContext.StudentExams
                .FirstOrDefaultAsync(se => se.StudentId == userId && se.ExamId == examId && se.SubmittedAt.HasValue);

            if (existing != null)
            {
                // Already taken, show result
                Snackbar.Add("You have already completed this exam. Redirecting to results...", Severity.Info);
                Navigation.NavigateTo($"/result/{existing.Id}");
                return;
            }

            // Start new exam
            var studentExam = new StudentExam
            {
                StudentId = userId,
                ExamId = examId,
                StartedAt = DateTime.UtcNow
            };
            DbContext.StudentExams.Add(studentExam);
            await DbContext.SaveChangesAsync();

            Snackbar.Add("Exam started", Severity.Success);
            Navigation.NavigateTo($"/take-exam/{studentExam.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to start exam: {ex.Message}", Severity.Error);
        }
    }
}