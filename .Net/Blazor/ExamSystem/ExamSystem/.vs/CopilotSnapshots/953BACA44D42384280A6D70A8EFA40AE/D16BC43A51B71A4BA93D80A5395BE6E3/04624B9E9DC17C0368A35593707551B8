@page "/result/{studentExamId:int}"
@attribute [Authorize(Roles = "Student")]

<PageTitle>Exam Result</PageTitle>

@if (studentExam != null)
{
    <MudText Typo="Typo.h4" GutterBottom="true">Exam Result: @studentExam.Exam?.Title</MudText>

    <MudCard Elevation="4" Class="pa-4 mb-4">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" md="3">
                    <MudText Typo="Typo.h6">Score</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@studentExam.Score / @studentExam.TotalQuestions</MudText>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudText Typo="Typo.h6">Percentage</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Secondary">@studentExam.Percentage:F1%</MudText>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudText Typo="Typo.h6">Status</MudText>
                    <MudChip T="string" Color="@(studentExam.Percentage >= 50 ? Color.Success : Color.Error)" Size="Size.Medium">
                        @(studentExam.Percentage >= 50 ? "Passed" : "Failed")
                    </MudChip>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudText Typo="Typo.h6">Submitted At</MudText>
                    <MudText Typo="Typo.body1">@studentExam.SubmittedAt?.ToString("g")</MudText>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    <MudText Typo="Typo.h5" GutterBottom="true">Review Answers</MudText>

    @foreach (var sa in studentExam.StudentAnswers)
    {
        <MudCard Elevation="2" Class="pa-3 mb-3" Style="@GetBorderStyle(sa.IsCorrect)">
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-2"><strong>@sa.Question?.Text</strong></MudText>
                <MudText Typo="Typo.body2" Color="@(sa.IsCorrect ? Color.Success : Color.Error)">
                    Your answer: @sa.SelectedAnswer?.Text
                </MudText>
                @if (!sa.IsCorrect)
                {
                    <MudText Typo="Typo.body2" Color="Color.Success">
                        Correct answer: @sa.Question?.Answers.First(a => a.IsCorrect).Text
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
    }

    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/subjects">Back to Subjects</MudButton>
}

@code {
    [Parameter] public int StudentExamId { get; set; }

    private StudentExam? studentExam;

    [Inject] private ApplicationDbContext DbContext { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        studentExam = await DbContext.StudentExams
            .Include(se => se.Exam)
            .Include(se => se.StudentAnswers)
                .ThenInclude(sa => sa.Question)
                    .ThenInclude(q => q.Answers)
            .Include(se => se.StudentAnswers)
                .ThenInclude(sa => sa.SelectedAnswer)
            .FirstOrDefaultAsync(se => se.Id == StudentExamId);
    }

    private string GetBorderStyle(bool isCorrect) => $"border-left: 4px solid {(isCorrect ? "green" : "red")};";
}