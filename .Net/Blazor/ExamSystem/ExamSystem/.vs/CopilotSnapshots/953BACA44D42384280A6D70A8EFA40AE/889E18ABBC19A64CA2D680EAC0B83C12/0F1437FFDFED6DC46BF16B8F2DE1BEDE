@page "/subjects"
@attribute [Authorize(Roles = "Student")]

<PageTitle>Subjects</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Available Subjects</MudText>

<MudGrid>
    @foreach (var subject in subjects)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="pa-4" Style="cursor: pointer;" OnClick="() => NavigateToExams(subject.Id)">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Subject" Size="Size.Large" Color="Color.Primary" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@subject.Name</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@subject.Description</MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">Exams: @subject.Exams.Count</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private List<Subject> subjects = new();

    [Inject] private ApplicationDbContext DbContext { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        subjects = await DbContext.Subjects.Include(s => s.Exams).ToListAsync();
    }

    private void NavigateToExams(int subjectId)
    {
        Navigation.NavigateTo($"/exams/{subjectId}");
    }
}