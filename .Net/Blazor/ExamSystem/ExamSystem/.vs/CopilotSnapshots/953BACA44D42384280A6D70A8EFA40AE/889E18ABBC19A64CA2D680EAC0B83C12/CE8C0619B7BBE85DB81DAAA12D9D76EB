@page "/take-exam/{studentExamId:int}"
@attribute [Authorize(Roles = "Student")]

<PageTitle>Take Exam</PageTitle>

@if (studentExam != null && questions.Any())
{
    <MudText Typo="Typo.h4" GutterBottom="true">@studentExam.Exam?.Title</MudText>

    <MudProgressLinear Value="@Progress" Color="Color.Primary" Class="mb-4" />

    <MudText Typo="Typo.body1" Class="mb-4">Question @currentQuestionIndex + 1 of @questions.Count</MudText>

    <MudCard Elevation="4" Class="pa-4">
        <MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-4">@currentQuestion.Text</MudText>

            <MudRadioGroup @bind-SelectedValue="selectedAnswerId" T="int">
                @foreach (var answer in currentQuestion.Answers)
                {
                    <MudRadio T="int" Option="@answer.Id" Color="Color.Primary">@answer.Text</MudRadio>
                }
            </MudRadioGroup>
        </MudCardContent>
    </MudCard>

    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
        <MudButton Variant="Variant.Outlined" Disabled="@(currentQuestionIndex == 0)" OnClick="PreviousQuestion">Previous</MudButton>
        @if (currentQuestionIndex < questions.Count - 1)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextQuestion">Next</MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SubmitExam" Disabled="@(!AllQuestionsAnswered)">Submit Exam</MudButton>
        }
    </MudStack>
}

<MudDialog @bind-IsVisible="@confirmSubmit" MaxWidth="MaxWidth.Small">
    <DialogContent>
        <MudText>Are you sure you want to submit the exam? You cannot change your answers after submission.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => confirmSubmit = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="ConfirmSubmit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int StudentExamId { get; set; }

    private StudentExam? studentExam;
    private List<Question> questions = new();
    private int currentQuestionIndex;
    private Question currentQuestion = new();
    private int? selectedAnswerId;
    private bool confirmSubmit;
    private Dictionary<int, int> answers = new();

    private double Progress => (double)(currentQuestionIndex + 1) / questions.Count * 100;
    private bool AllQuestionsAnswered => answers.Count == questions.Count;

    [Inject] private ApplicationDbContext DbContext { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        studentExam = await DbContext.StudentExams
            .Include(se => se.Exam)
            .Include(se => se.StudentAnswers)
            .FirstOrDefaultAsync(se => se.Id == StudentExamId);

        if (studentExam != null)
        {
            questions = await DbContext.Questions
                .Include(q => q.Answers)
                .Where(q => q.ExamId == studentExam.ExamId)
                .OrderBy(q => q.Order)
                .ToListAsync();

            // Load existing answers
            foreach (var sa in studentExam.StudentAnswers)
            {
                answers[sa.QuestionId] = sa.SelectedAnswerId;
            }

            UpdateCurrentQuestion();
        }
    }

    private void UpdateCurrentQuestion()
    {
        if (questions.Any() && currentQuestionIndex < questions.Count)
        {
            currentQuestion = questions[currentQuestionIndex];
            selectedAnswerId = answers.ContainsKey(currentQuestion.Id) ? answers[currentQuestion.Id] : (int?)null;
        }
    }

    private void NextQuestion()
    {
        if (selectedAnswerId.HasValue)
        {
            answers[currentQuestion.Id] = selectedAnswerId.Value;
        }

        if (currentQuestionIndex < questions.Count - 1)
        {
            currentQuestionIndex++;
            UpdateCurrentQuestion();
        }
    }

    private void PreviousQuestion()
    {
        if (selectedAnswerId.HasValue)
        {
            answers[currentQuestion.Id] = selectedAnswerId.Value;
        }

        if (currentQuestionIndex > 0)
        {
            currentQuestionIndex--;
            UpdateCurrentQuestion();
        }
    }

    private void SubmitExam()
    {
        confirmSubmit = true;
    }

    private async Task ConfirmSubmit()
    {
        // Save final answer
        if (selectedAnswerId.HasValue)
        {
            answers[currentQuestion.Id] = selectedAnswerId.Value;
        }

        // Calculate score
        int score = 0;
        foreach (var q in questions)
        {
            if (answers.ContainsKey(q.Id))
            {
                var selectedAnswer = q.Answers.FirstOrDefault(a => a.Id == answers[q.Id]);
                if (selectedAnswer?.IsCorrect == true)
                {
                    score++;
                }

                // Save student answer
                var studentAnswer = new StudentAnswer
                {
                    StudentExamId = StudentExamId,
                    QuestionId = q.Id,
                    SelectedAnswerId = answers[q.Id]
                };
                DbContext.StudentAnswers.Add(studentAnswer);
            }
        }

        studentExam!.Score = score;
        studentExam.TotalQuestions = questions.Count;
        studentExam.SubmittedAt = DateTime.UtcNow;

        await DbContext.SaveChangesAsync();

        Navigation.NavigateTo($"/result/{StudentExamId}");
        Snackbar.Add("Exam submitted successfully!", Severity.Success);
    }
}