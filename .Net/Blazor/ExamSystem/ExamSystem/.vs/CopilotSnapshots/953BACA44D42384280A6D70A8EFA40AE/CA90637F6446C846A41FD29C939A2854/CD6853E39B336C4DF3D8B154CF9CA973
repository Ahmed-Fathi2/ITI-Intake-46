@page "/"

<PageTitle>Exam System</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex flex-column align-center justify-center" Style="min-height: 60vh;">
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">Welcome to Exam System</MudText>
    <MudText Typo="Typo.h6" Align="Align.Center" Color="Color.Secondary" GutterBottom="true">
        A modern, full-stack exam management system built with Blazor and ASP.NET Core.
    </MudText>

    <AuthorizeView Context="authContext">
        <Authorized>
            <MudText Typo="Typo.body1" Align="Align.Center" GutterBottom="true">
                Hello @authContext.User.Identity?.Name! Navigate using the menu to access your features.
            </MudText>
            <AuthorizeView Roles="Student" Context="studentContext">
                <Authorized>
                    <MudStack Row="true" Justify="Justify.Center" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/subjects">Browse Subjects</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/my-exams">My Exams</MudButton>
                    </MudStack>
                </Authorized>
            </AuthorizeView>
            <AuthorizeView Roles="Admin" Context="adminContext">
                <Authorized>
                    <MudStack Row="true" Justify="Justify.Center" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/dashboard">Admin Dashboard</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/admin/subjects">Manage Subjects</MudButton>
                    </MudStack>
                </Authorized>
            </AuthorizeView>
        </Authorized>
        <NotAuthorized>
            <MudText Typo="Typo.body1" Align="Align.Center" GutterBottom="true">
                Please login or register to access the system.
            </MudText>
            <MudStack Row="true" Justify="Justify.Center" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/Account/Login">Login</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/Account/Register">Register</MudButton>
            </MudStack>
        </NotAuthorized>
    </AuthorizeView>

    <MudDivider Class="my-4" />

    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="pa-4">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Large" Color="Color.Primary" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Admin Features</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Manage subjects, exams, questions, and monitor student performance.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="pa-4">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Large" Color="Color.Secondary" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Student Portal</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Take exams, view results, and track your progress.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="pa-4">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Large" Color="Color.Tertiary" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Secure & Modern</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Built with ASP.NET Core Identity and modern UI components.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>
