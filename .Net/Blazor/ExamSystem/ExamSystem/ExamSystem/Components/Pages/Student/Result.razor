@page "/result/{studentExamId:int}"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using ExamSystem.Data

<PageTitle>Exam Result | @(studentExam?.Exam?.Title ?? "Result")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-10 mb-16 px-4">
    @if (studentExam == null)
    {
        <div class="d-flex flex-column align-items-center justify-center pt-16">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4">Loading your results...</MudText>
        </div>
    }
    else
    {
        <MudCard Elevation="2" Class="pa-8 mb-8 rounded-lg">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h4" Class="font-weight-bold">Exam Result</MudText>
                    <MudText Typo="Typo.subtitle1">@studentExam.Exam?.Title</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudText Typo="Typo.h3" Color="@(studentExam.Percentage >= 50 ? Color.Success : Color.Error)" Class="font-weight-bold">
                        @studentExam.Percentage.ToString("F0")%
                    </MudText>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Spacing="4">
                    <MudItem xs="6">
                        <MudText Typo="Typo.body1">Score: <b>@studentExam.Score / @studentExam.TotalQuestions</b></MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.body1">Status: <b class="@(studentExam.Percentage >= 50 ? "text-success" : "text-error")">@(studentExam.Percentage >= 50 ? "Passed" : "Failed")</b></MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.body2" Class="opacity-7">Submitted on: @studentExam.SubmittedAt?.ToString("MMMM dd, yyyy - hh:mm tt")</MudText>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/subjects" Class="mr-2">Back to Subjects</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/">Dashboard</MudButton>
            </MudCardActions>
        </MudCard>

        <MudText Typo="Typo.h5" Class="mb-4">Review Answers</MudText>

        @foreach (var (sa, index) in studentExam.StudentAnswers.Select((val, i) => (val, i + 1)))
        {
            <MudPaper Elevation="1" Class="pa-4 mb-4 rounded-lg">
                <div class="d-flex align-center mb-2">
                    <MudAvatar Color="@(sa.IsCorrect ? Color.Success : Color.Error)" Size="Size.Small" Class="mr-3">@index</MudAvatar>
                    <MudText Typo="Typo.h6">@sa.Question?.Text</MudText>
                </div>
                
                <MudDivider Class="my-3"/>
                
                <div class="ml-10">
                    <MudText Typo="Typo.body1" Class="@(sa.IsCorrect ? "text-success" : "text-error")">
                        Your Answer: <b>@sa.SelectedAnswer?.Text</b>
                    </MudText>
                    
                    @if (!sa.IsCorrect)
                    {
                        <MudText Typo="Typo.body1" Color="Color.Primary" Class="mt-1">
                            Correct Answer: <b>@sa.Question?.Answers.FirstOrDefault(a => a.IsCorrect)?.Text</b>
                        </MudText>
                    }
                </div>
            </MudPaper>
        }
    }
</MudContainer>

<style>
    .text-success { color: var(--mud-palette-success); }
    .text-error { color: var(--mud-palette-error); }
</style>

@code {
    [Parameter] public int StudentExamId { get; set; }

    private StudentExam? studentExam;

    [Inject] private ApplicationDbContext DbContext { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        studentExam = await DbContext.StudentExams
            .Include(se => se.Exam)
            .Include(se => se.StudentAnswers)
                .ThenInclude(sa => sa.Question)
                    .ThenInclude(q => q.Answers)
            .Include(se => se.StudentAnswers)
                .ThenInclude(sa => sa.SelectedAnswer)
            .FirstOrDefaultAsync(se => se.Id == StudentExamId);
    }
}