@inherits LayoutComponentBase

<MudThemeProvider Theme="_myTheme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" Style="backdrop-filter: blur(10px); background-color: rgba(var(--mud-palette-primary-rgb), 0.9);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3 font-weight-bold">Exam System</MudText>
        <MudSpacer />
        
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                       Color="Color.Inherit" OnClick="ToggleDarkMode" Class="mr-2" />

        <AuthorizeView Context="authState">
            <Authorized>
                <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Small" Class="mr-2">
                            @authState.User.Identity?.Name?.Substring(0, 1).ToUpper()
                        </MudAvatar>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Disabled="true">
                            <MudText Typo="Typo.body2">@authState.User.Identity?.Name</MudText>
                        </MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="Logout">Logout</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Href="Account/Login" Class="rounded-pill mr-2">Login</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="Account/Register" Class="rounded-pill">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Docked">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.Large" Class="mb-16">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private MudTheme _myTheme = new()
        {
            PaletteLight = new MudBlazor.PaletteLight()
            {
                Primary = "#6366f1", // Indigo
                Secondary = "#ec4899", // Pink
                AppbarBackground = "#6366f1",
                Background = "#f8fafc",
                Surface = "#ffffff",
                DrawerBackground = "#ffffff",
                ActionDefault = "#475569",
                TextPrimary = "#1e293b",
                TextSecondary = "#64748b"
            },
            PaletteDark = new MudBlazor.PaletteDark()
            {
                Primary = "#818cf8",
                Secondary = "#f472b6",
                Background = "#0f172a",
                Surface = "#1e293b",
                AppbarBackground = "#1e293b",
                DrawerBackground = "#1e293b",
                TextPrimary = "#f1f5f9",
                TextSecondary = "#94a3b8"
            },
            LayoutProperties = new MudBlazor.LayoutProperties()
            {
                DefaultBorderRadius = "12px",
                AppbarHeight = "72px"
            }
        };

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
    }

    private void Logout()
    {
        Navigation.NavigateTo("/Account/Logout" + "?returnUrl=/", forceLoad: true);
    }
}
