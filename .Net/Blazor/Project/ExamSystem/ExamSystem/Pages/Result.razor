@page "/result/{id:int}"
@inject ApplicationDbContext Db

<h3>Result</h3>

@if (result == null)
{
    <p>Loading...</p>
}
else
{
    <p>Score: @result.Score</p>
    <p>Submitted At: @result.SubmittedAt</p>
}

@code {
    [Parameter]
    public int id { get; set; }

    private StudentExam? result;

    protected override async Task OnInitializedAsync()
    {
        result = await Db.StudentExams.Include(s => s.Exam).FirstOrDefaultAsync(x => x.Id == id);
    }
}
