@page "/login"
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ExamSystem.Models.ApplicationUser> SignInManager
@inject NavigationManager Nav

<h3>Login</h3>

<EditForm Model="model" OnValidSubmit="DoLogin">
    <input type="email" @bind="model.Email" placeholder="Email" />
    <input type="password" @bind="model.Password" placeholder="Password" />
    <button type="submit">Login</button>
</EditForm>

@code {
    private LoginModel model = new();

    class LoginModel { public string Email { get; set; } = string.Empty; public string Password { get; set; } = string.Empty; }

    async Task DoLogin()
    {
        var result = await SignInManager.PasswordSignInAsync(model.Email, model.Password, isPersistent: false, lockoutOnFailure: false);
        if (result.Succeeded)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            // simplified error handling
        }
    }
}
