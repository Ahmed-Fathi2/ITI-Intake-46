@page "/register"
@using Microsoft.AspNetCore.Identity
@inject UserManager<ExamSystem.Models.ApplicationUser> UserManager
@inject NavigationManager Nav

<h3>Register</h3>

<EditForm Model="model" OnValidSubmit="RegisterUser">
    <InputText @bind-Value="model.Email" placeholder="Email" />
    <InputText @bind-Value="model.Password" placeholder="Password" />
    <button type="submit">Register</button>
</EditForm>

@code {
    private RegisterModel model = new();

    class RegisterModel { public string Email { get; set; } = string.Empty; public string Password { get; set; } = string.Empty; }

    async Task RegisterUser()
    {
        var user = new ExamSystem.Models.ApplicationUser { UserName = model.Email, Email = model.Email };
        var result = await UserManager.CreateAsync(user, model.Password);
        if (result.Succeeded)
        {
            // Assign Student role
            await UserManager.AddToRoleAsync(user, "Student");
            Nav.NavigateTo("/");
        }
        else
        {
            // show errors - simplified
        }
    }
}
