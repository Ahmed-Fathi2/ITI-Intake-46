@page "/admin/subjects"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Manage Subjects</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Manage Subjects</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">Add Subject</MudButton>

<MudTable Items="@subjects" Hover="true" Elevation="4" Class="mt-4">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Exams Count</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.Description</MudTd>
        <MudTd>@context.Exams.Count</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => OpenEditDialog(context)" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteSubject(context)" />
        </MudTd>
    </RowTemplate>
</MudTable>

<MudDialog @bind-Visible="@dialogOpen" MaxWidth="MaxWidth.Small">
    <TitleContent>
        <MudText Typo="Typo.h6" Class="font-weight-bold d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Class="mr-2" Color="Color.Primary" />
            @(subject.Id == 0 ? "Add New Subject" : "Edit Subject")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form">
            <MudPaper Elevation="0" Class="pa-4 rounded-xl" Style="background: rgba(var(--mud-palette-primary-rgb), 0.03); border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.1);">
                <MudTextField @bind-Value="subject.Name" Label="Subject Name" Variant="Variant.Outlined" Required="true" RequiredError="Subject Name is required!" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Title" Class="mb-4 bg-transparent" />
                <MudTextField @bind-Value="subject.Description" Label="Subject Description" Variant="Variant.Outlined" Lines="3" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Description" Class="bg-transparent" />
            </MudPaper>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog" Class="rounded-pill font-weight-bold px-6">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSubject" Class="rounded-pill font-weight-bold px-8" StartIcon="@Icons.Material.Filled.Save">Save Changes</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Subject> subjects = new();
    private bool dialogOpen;
    private Subject subject = new();
    private MudForm form = default!;

    [Inject] private IDbContextFactory<ApplicationDbContext> DbFactory { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubjects();
    }

    private async Task LoadSubjects()
    {
        await using var db = DbFactory.CreateDbContext();
        subjects = await db.Subjects
            .Include(s => s.Exams)
            .AsNoTracking()
            .ToListAsync();
        StateHasChanged();
    }

    private void OpenCreateDialog()
    {
        subject = new Subject();
        dialogOpen = true;
        // Reset form slightly after opening or let it reset gracefully
        StateHasChanged();
    }

    private void OpenEditDialog(Subject subj)
    {
        subject = new Subject { Id = subj.Id, Name = subj.Name, Description = subj.Description };
        dialogOpen = true;
        StateHasChanged();
    }

    private void CloseDialog()
    {
        dialogOpen = false;
        form?.ResetAsync();
    }

    private async Task SaveSubject()
    {
        await form.ValidateAsync();
        if (!form.IsValid) return;
        
        await using var db = DbFactory.CreateDbContext();
        try
        {
            if (subject.Id == 0)
            {
                subject.Name = subject.Name ?? "";
                subject.Description = subject.Description ?? "";
                db.Subjects.Add(subject);
            }
            else
            {
                var existing = await db.Subjects.FindAsync(subject.Id);
                if (existing != null)
                {
                    existing.Name = subject.Name ?? "";
                    existing.Description = subject.Description ?? "";
                }
            }
            await db.SaveChangesAsync();
            await LoadSubjects();
            CloseDialog();
            Snackbar.Add("Subject saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            db.ChangeTracker.Clear();
            Snackbar.Add("Failed to save subject: " + (ex.InnerException?.Message ?? ex.Message), Severity.Error);
        }
    }

    private async Task DeleteSubject(Subject subj)
    {
        await using var db = DbFactory.CreateDbContext();
        try
        {
            var existing = await db.Subjects.FindAsync(subj.Id);
            if (existing != null)
            {
                db.Subjects.Remove(existing);
                await db.SaveChangesAsync();
                await LoadSubjects();
                Snackbar.Add("Subject deleted", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            db.ChangeTracker.Clear();
            string msg = ex.InnerException?.Message ?? ex.Message;
            if (msg.Contains("REFERENCE constraint") || msg.Contains("FOREIGN KEY constraint"))
            {
                Snackbar.Add("Cannot delete subject because it has exams.", Severity.Error);
            }
            else
            {
                Snackbar.Add("Failed to delete subject: " + msg, Severity.Error);
            }
        }
    }
}