using Microsoft.AspNetCore.Identity;
using Microsoft.EntityFrameworkCore;

namespace ExamSystem.Data
{
    public static class DataSeeder
    {
        public static async Task SeedAsync(IServiceProvider serviceProvider)
        {
            using var scope = serviceProvider.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            var roleManager = scope.ServiceProvider.GetRequiredService<RoleManager<IdentityRole>>();

            // Ensure database is created
            await context.Database.MigrateAsync();

            // Seed roles
            if (!await roleManager.RoleExistsAsync("Admin"))
            {
                await roleManager.CreateAsync(new IdentityRole("Admin"));
            }
            if (!await roleManager.RoleExistsAsync("Student"))
            {
                await roleManager.CreateAsync(new IdentityRole("Student"));
            }

            // Seed admin user
            var adminEmail = "admin@examsystem.com";
            var adminUser = await userManager.FindByEmailAsync(adminEmail);
            if (adminUser == null)
            {
                adminUser = new ApplicationUser
                {
                    UserName = adminEmail,
                    Email = adminEmail,
                    EmailConfirmed = true
                };
                var result = await userManager.CreateAsync(adminUser, "Admin123!");
                if (result.Succeeded)
                {
                    await userManager.AddToRoleAsync(adminUser, "Admin");
                }
            }

            // Seed a test student user for manual testing
            var studentEmail = "student@examsystem.com";
            var studentUser = await userManager.FindByEmailAsync(studentEmail);
            if (studentUser == null)
            {
                studentUser = new ApplicationUser
                {
                    UserName = studentEmail,
                    Email = studentEmail,
                    EmailConfirmed = true
                };
                var sResult = await userManager.CreateAsync(studentUser, "Student123!");
                if (sResult.Succeeded)
                {
                    await userManager.AddToRoleAsync(studentUser, "Student");
                }
            }

            // Seed sample data
            if (!await context.Subjects.AnyAsync())
            {
                var mathSubject = new Subject { Name = "Mathematics", Description = "Basic Mathematics" };
                var scienceSubject = new Subject { Name = "Science", Description = "General Science" };

                context.Subjects.AddRange(mathSubject, scienceSubject);
                await context.SaveChangesAsync();

                // Seed exams
                var mathExam = new Exam
                {
                    Title = "Algebra Basics",
                    Description = "Test your algebra knowledge",
                    SubjectId = mathSubject.Id,
                    DurationMinutes = 30
                };

                var scienceExam = new Exam
                {
                    Title = "Physics Fundamentals",
                    Description = "Basic physics concepts",
                    SubjectId = scienceSubject.Id,
                    DurationMinutes = 45
                };

                context.Exams.AddRange(mathExam, scienceExam);
                await context.SaveChangesAsync();

                // Seed questions for math exam
                var q1 = new Question { Text = "What is 2 + 2?", ExamId = mathExam.Id, Order = 1 };
                var q2 = new Question { Text = "What is 5 * 3?", ExamId = mathExam.Id, Order = 2 };

                context.Questions.AddRange(q1, q2);
                await context.SaveChangesAsync();

                // Answers for q1
                context.Answers.AddRange(
                    new Answer { Text = "3", QuestionId = q1.Id, IsCorrect = false },
                    new Answer { Text = "4", QuestionId = q1.Id, IsCorrect = true },
                    new Answer { Text = "5", QuestionId = q1.Id, IsCorrect = false },
                    new Answer { Text = "6", QuestionId = q1.Id, IsCorrect = false }
                );

                // Answers for q2
                context.Answers.AddRange(
                    new Answer { Text = "8", QuestionId = q2.Id, IsCorrect = false },
                    new Answer { Text = "12", QuestionId = q2.Id, IsCorrect = false },
                    new Answer { Text = "15", QuestionId = q2.Id, IsCorrect = true },
                    new Answer { Text = "20", QuestionId = q2.Id, IsCorrect = false }
                );

                await context.SaveChangesAsync();
            }
        }
    }
}