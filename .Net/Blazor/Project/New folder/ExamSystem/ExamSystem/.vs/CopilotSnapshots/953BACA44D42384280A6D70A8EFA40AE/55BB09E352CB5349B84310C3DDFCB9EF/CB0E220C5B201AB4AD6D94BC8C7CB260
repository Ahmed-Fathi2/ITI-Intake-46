@page "/my-exams"
@attribute [Authorize(Roles = "Student")]

<PageTitle>My Exams</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">My Exam History</MudText>

@if (studentExams.Any())
{
    <MudTable Items="@studentExams" Hover="true" Elevation="4">
        <HeaderContent>
            <MudTh>Exam</MudTh>
            <MudTh>Subject</MudTh>
            <MudTh>Score</MudTh>
            <MudTh>Percentage</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Submitted At</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Exam?.Title</MudTd>
            <MudTd>@context.Exam?.Subject?.Name</MudTd>
            <MudTd>@context.Score / @context.TotalQuestions</MudTd>
            <MudTd>@context.Percentage:F1%</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.Percentage >= 50 ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.Percentage >= 50 ? "Passed" : "Failed")
                </MudChip>
            </MudTd>
            <MudTd>@context.SubmittedAt?.ToString("g")</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="@($"/result/{context.Id}")">View Details</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else
{
    <MudText Typo="Typo.body1" Color="Color.Secondary">You haven't taken any exams yet.</MudText>
}

@code {
    private List<StudentExam> studentExams = new();

    [Inject] private ApplicationDbContext DbContext { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthState { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst("sub")?.Value ?? authState.User.Identity?.Name;

        if (userId != null)
        {
            studentExams = await DbContext.StudentExams
                .Include(se => se.Exam)
                    .ThenInclude(e => e.Subject)
                .Where(se => se.StudentId == userId && se.IsCompleted)
                .OrderByDescending(se => se.SubmittedAt)
                .ToListAsync();
        }
    }
}